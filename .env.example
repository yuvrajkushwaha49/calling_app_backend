NODE_ENV=production
PORT=5000
HOST=127.0.0.1

# Comma-separated frontend origins allowed by browser CORS.
# Example: https://your-domain.com,https://www.your-domain.com
CORS_ORIGIN=https://your-domain.com

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=telecaller_app
DB_PASSWORD=replace_with_a_strong_database_password
DB_NAME=telecaller_crm

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# Set to true only while creating the first super admin, then set back to false.
ENABLE_SETUP_ROUTE=false
